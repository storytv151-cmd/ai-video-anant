# Core application configuration
PORT=5000
NODE_ENV=development
APP_NAME=AI Video Generation Platform Backend
APP_VERSION=1.0.0
API_BASE_PATH=/api
API_VERSION=v1
CLIENT_URL=http://localhost:3000
TRUST_PROXY=1

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-video-platform?retryWrites=true&w=majority
MONGO_DB_NAME=ai-video-platform
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_POOL_SIZE=20
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# JWT placeholders for future authentication phases
JWT_SECRET=replace-with-access-secret
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Google integration placeholder
GOOGLE_CLIENT_ID=replace-with-google-client-id

# DigitalOcean Spaces / S3-compatible object storage
DIGITALOCEAN_SPACES_KEY=replace-with-spaces-key
DIGITALOCEAN_SPACES_SECRET=replace-with-spaces-secret
DIGITALOCEAN_SPACES_BUCKET=replace-with-spaces-bucket
DIGITALOCEAN_SPACES_REGION=replace-with-spaces-region
DIGITALOCEAN_SPACES_ENDPOINT=https://region.digitaloceanspaces.com
DIGITALOCEAN_SPACES_CDN=https://cdn.example.com

# Future AI provider API keys
NANO_BANANA_API_KEY=replace-with-nano-banana-api-key
KLING_API_KEY=replace-with-kling-api-key
PIKA_API_KEY=replace-with-pika-api-key
RUNWAY_API_KEY=replace-with-runway-api-key
LUMA_API_KEY=replace-with-luma-api-key

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m

# Security and request handling
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
BODY_LIMIT=2mb
COOKIE_SECRET=replace-with-cookie-secret
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Uploads and media processing
UPLOAD_MAX_FILE_SIZE=52428800
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,video/mp4,video/quicktime
SHARP_CONCURRENCY=4

# Cron and background jobs
CRON_TIMEZONE=UTC
ENABLE_CRON_JOBS=false

# Observability
ENABLE_HTTP_LOGGING=true
ENABLE_REQUEST_ID_HEADER=true
